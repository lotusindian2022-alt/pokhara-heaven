# Reservations email delivery (used by src/pages/api/reservar.ts)
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Uses Resend (https://resend.com) over its REST API — no extra npm dependency.
# If RESEND_API_KEY is left blank, the reservations endpoint still validates and
# accepts submissions (logging them to the server console) so you can develop
# without an email provider wired up.

RESEND_API_KEY=
# Address that receives reservation requests (the restaurant inbox):
RESERVATION_TO_EMAIL=Pokharaheaven5@gmail.com
# Sender address — must be on a domain you've verified in Resend (Gmail won't work
# as a sender). For quick testing you can use Resend's onboarding@resend.dev.
RESERVATION_FROM_EMAIL=reservas@pokharaheaven.es
