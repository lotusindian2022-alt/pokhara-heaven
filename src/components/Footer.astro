---
import { site } from '../data/site';

interface Props {
  /** Lattice overlay opacity (Home "motif" prop: subtle 0.08 / bold 0.16 / none 0). */
  latticeOpacity?: number;
}
const { latticeOpacity = 0.08 } = Astro.props;
---

<footer
  style="position:relative; background:var(--dark); color:var(--cream); padding:72px var(--gutter-home) 40px; overflow:hidden;"
>
  <div
    style={`position:absolute; inset:0; opacity:${latticeOpacity}; background-image:var(--pattern-lattice); pointer-events:none;`}
    aria-hidden="true"
  >
  </div>

  <div
    class="v2-foot"
    style="position:relative; display:grid; grid-template-columns:1.4fr 1fr 1fr; gap:40px; padding-bottom:40px; border-bottom:1px solid rgba(247,241,230,0.16);"
  >
    <div>
      <div style="display:flex; align-items:baseline; gap:10px;">
        <span style="font-family:'Fraunces',serif; font-weight:600; font-size:17px; color:var(--gold-bright);">
          {site.brandDevanagari}
        </span>
        <span style="font-family:'Fraunces',serif; font-weight:600; font-size:27px;">{site.name}</span>
      </div>
      <p style="font-size:17px; line-height:1.65; color:rgba(247,241,230,0.72); margin:16px 0 0; max-width:38ch;">
        {site.tagline}
      </p>
      <a
        href={site.instagram.url}
        rel="me noopener"
        target="_blank"
        style="display:inline-flex; align-items:center; gap:10px; margin-top:22px; color:var(--gold-bright); text-decoration:none; font-weight:600; font-size:17px;"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line>
        </svg>
        {site.instagram.handle}
      </a>
    </div>

    <div>
      <span style="display:block; font-size:14px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-bright); margin-bottom:16px;">
        Menú
      </span>
      <div style="display:flex; flex-direction:column; gap:10px; font-size:17px;">
        <a href="/#historia" style="color:rgba(247,241,230,0.8); text-decoration:none;">Historia</a>
        <a href="/#platos" style="color:rgba(247,241,230,0.8); text-decoration:none;">Platos</a>
        <a href="/carta" style="color:rgba(247,241,230,0.8); text-decoration:none;">Carta completa</a>
        <a href="/#pedir" style="color:rgba(247,241,230,0.8); text-decoration:none;">Pedir a domicilio</a>
      </div>
    </div>

    <div>
      <span style="display:block; font-size:14px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--gold-bright); margin-bottom:16px;">
        Contacto
      </span>
      <div style="font-size:17px; line-height:1.9; color:rgba(247,241,230,0.8);">
        {site.address.line1}<br />
        {site.address.line2}<br />
        <a href={site.phoneHref} style="color:inherit; text-decoration:none;">{site.phone}</a><br />
        <a href={`mailto:${site.email}`} style="color:inherit; text-decoration:none;">{site.email}</a>
      </div>
    </div>
  </div>

  <div
    style="position:relative; display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; padding-top:28px; font-size:15px; color:rgba(247,241,230,0.55);"
  >
    <span>© 2026 {site.name} · Restaurante nepalí</span>
    <span>Los precios incluyen IVA · धन्यवाद</span>
  </div>
</footer>
