---
/** Prayer-flag accent bar — 5px row of colored stripes at the very top of each page. */
---
<div class="ph-flag" aria-hidden="true">
  <span style="background: var(--flag-blue);"></span>
  <span style="background: var(--flag-white);"></span>
  <span style="background: var(--red);"></span>
  <span style="background: var(--flag-green);"></span>
  <span style="background: var(--gold);"></span>
</div>

<style>
  .ph-flag { display: flex; height: 5px; }
  .ph-flag span { flex: 1; }
</style>
