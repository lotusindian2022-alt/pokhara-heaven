---
import ImageSlot from './ImageSlot.astro';

interface Props {
  title: string;
  price: string;
  placeholder: string;
  tone?: 'warm' | 'dark' | 'ember' | 'green';
  src?: ImageMetadata;
  /** If set, the card links to the dish (same-page anchor on the menu). */
  href?: string;
}
const { title, price, placeholder, tone = 'warm', src, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  class="m-gcard"
  href={href}
  aria-label={href ? `${title} — ir al plato` : undefined}
  style="display:block; text-decoration:none; color:inherit; background:var(--surface); border-radius:var(--radius-card); overflow:hidden; box-shadow:0 10px 30px rgba(46,23,18,0.08); border:1px solid rgba(43,35,32,0.06);"
>
  <div style="position:relative; aspect-ratio:1/1; overflow:hidden;">
    <div class="m-gimg" style="position:absolute; inset:0;">
      <ImageSlot
        src={src}
        placeholder={placeholder}
        alt={title}
        tone={tone}
        showLabel={false}
        sizes="(max-width:560px) 50vw, (max-width:820px) 50vw, 275px"
        widths={[275, 400, 550]}
      />
    </div>
  </div>
  <div style="padding:16px 18px; display:flex; justify-content:space-between; align-items:baseline; gap:10px;">
    <span style="font-family:'Marcellus',serif; font-size:19px; color:var(--ink);">{title}</span>
    <span style="font-family:'Mukta',sans-serif; font-weight:700; font-size:16px; color:var(--terracotta); white-space:nowrap;">
      {price}
    </span>
  </div>
</Tag>
